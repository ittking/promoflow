# 部署环境类型：DEVELOPMENT（开发环境）/ PRODUCTION（生产环境）
NEXT_PUBLIC_DEPLOY_ENV=DEVELOPMENT

# 部署版本类型：SELF_HOSTED（自托管）
NEXT_PUBLIC_EDITION=SELF_HOSTED

# 应用基础路径：如果部署在子目录下需要设置，例如 /dify
NEXT_PUBLIC_BASE_PATH=

# 控制台 API 地址：用于服务端请求，通常与 Docker 部署中的 CONSOLE_API_URL 一致
# 本地开发时可使用 NEXT_PUBLIC_API_PREFIX 作为后备
CONSOLE_API_URL=http://localhost:5001

# 控制台 API 前缀地址：当控制台域名与 API 或 Web 应用域名不同时设置
# 示例：https://cloud.dify.ai/console/api
NEXT_PUBLIC_API_PREFIX=http://localhost:3001/console/api

# 公开 API 前缀地址：当 Web 应用域名与控制台或 API 域名不同时设置
# 示例：https://udify.app/api
NEXT_PUBLIC_PUBLIC_API_PREFIX=http://localhost:3001/api

# Cookie 域名：当前端和后端运行在不同子域名时，设置为 1
NEXT_PUBLIC_COOKIE_DOMAIN=

# WebSocket 服务器地址
NEXT_PUBLIC_SOCKET_URL=ws://localhost:5001

# 开发代理配置（位于 web/dev-proxy.config.ts）
# pnpm -C web run dev:proxy 会先加载 web/.env.local 再读取该配置文件
DEV_PROXY_TARGET=http://localhost:5001
# 默认为 DEV_PROXY_TARGET；当公开 API 使用不同源时设置此项
DEV_PROXY_PUBLIC_TARGET=http://localhost:5001
DEV_PROXY_HOST=127.0.0.1
DEV_PROXY_PORT=3001

# 市场 API 前缀
NEXT_PUBLIC_MARKETPLACE_API_PREFIX=https://marketplace.dify.ai/api/v1

# 市场网址前缀
NEXT_PUBLIC_MARKETPLACE_URL_PREFIX=https://marketplace.dify.ai

# Sentry 错误监控 DSN（用于生产环境错误追踪）
NEXT_PUBLIC_SENTRY_DSN=

# 禁用 Next.js 遥测数据收集（https://nextjs.org/telemetry）
NEXT_TELEMETRY_DISABLED=1

# 上传图片作为 Web 应用图标（默认 false）
NEXT_PUBLIC_UPLOAD_IMAGE_AS_ICON=false

# 文本生成超时时间（毫秒）
NEXT_PUBLIC_TEXT_GENERATION_TIMEOUT_MS=60000
# Docker 启动时由 web/docker/entrypoint.sh 覆盖/导出此值（仅 Docker 环境）
TEXT_GENERATION_TIMEOUT_MS=60000

# CSP 内容安全策略 https://developer.mozilla.org/zh-CN/docs/Web/HTTP/CSP
NEXT_PUBLIC_CSP_WHITELIST=

# 是否允许嵌入 iframe（默认不允许，防止点击劫持攻击）https://owasp.org/www-community/attacks/Clickjacking
NEXT_PUBLIC_ALLOW_EMBED=

# 允许在 Markdown 渲染中使用内联样式（自托管可选开启，默认 false）
NEXT_PUBLIC_ALLOW_INLINE_STYLES=false

# 允许渲染 data: 协议的 unsafe URL（默认 false）
NEXT_PUBLIC_ALLOW_UNSAFE_DATA_SCHEME=false

# RAG 检索的最大 top-k 值
NEXT_PUBLIC_TOP_K_MAX_VALUE=10

# 分段最大 Token 数量
NEXT_PUBLIC_INDEXING_MAX_SEGMENTATION_TOKENS_LENGTH=4000
# Docker 启动时由 web/docker/entrypoint.sh 覆盖/导出此值（仅 Docker 环境）
INDEXING_MAX_SEGMENTATION_TOKENS_LENGTH=4000

# 工作流最大循环次数
NEXT_PUBLIC_LOOP_NODE_MAX_COUNT=100

# Agent/工作流中最大工具数量
NEXT_PUBLIC_MAX_TOOLS_NUM=10

# 工作流最大并行分支数
NEXT_PUBLIC_MAX_PARALLEL_LIMIT=10

# Agent 最大迭代次数
NEXT_PUBLIC_MAX_ITERATIONS_NUM=99

# 是否启用 Jina Reader 网站抓取
NEXT_PUBLIC_ENABLE_WEBSITE_JINAREADER=true

# 是否启用 Firecrawl 网站抓取
NEXT_PUBLIC_ENABLE_WEBSITE_FIRECRAWL=true

# 是否启用 Watercrawl 网站抓取
NEXT_PUBLIC_ENABLE_WEBSITE_WATERCRAWL=true

# 启用单美元符号内联 LaTeX 渲染（$...$）
# 出于安全原因默认关闭，以防与普通文本冲突
NEXT_PUBLIC_ENABLE_SINGLE_DOLLAR_LATEX=false

# 启用预览功能（目前为 /create 和 /refine 命令）
# 位于"转到任意内容"命令面板中
NEXT_PUBLIC_ENABLE_FEATURE_PREVIEW=false

# 启用 Agent V2 前端入口
NEXT_PUBLIC_ENABLE_AGENT_V2=false

# 工作流最大树节点深度
NEXT_PUBLIC_MAX_TREE_DEPTH=50

# Amplitude 分析 API 密钥
NEXT_PUBLIC_AMPLITUDE_API_KEY=

# 批处理并发数
NEXT_PUBLIC_BATCH_CONCURRENCY=5

# 云系统功能前端默认值
# 仅在 NEXT_PUBLIC_EDITION=CLOUD（云版本）时生效
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_EMAIL_CODE_LOGIN=true
NEXT_PUBLIC_ENABLE_EMAIL_PASSWORD_LOGIN=false
NEXT_PUBLIC_ENABLE_SOCIAL_OAUTH_LOGIN=true
NEXT_PUBLIC_ENABLE_COLLABORATION_MODE=false
NEXT_PUBLIC_ALLOW_REGISTER=true
NEXT_PUBLIC_ALLOW_CREATE_WORKSPACE=true
NEXT_PUBLIC_IS_EMAIL_SETUP=true
NEXT_PUBLIC_ENABLE_CHANGE_EMAIL=true
NEXT_PUBLIC_CREATORS_PLATFORM_FEATURES_ENABLED=true
NEXT_PUBLIC_ENABLE_TRIAL_APP=true
NEXT_PUBLIC_ENABLE_EXPLORE_BANNER=true
NEXT_PUBLIC_RBAC_ENABLED=false